# 个人助理环境变量模板
# 复制本文件为 .env 并填入真实值。.env 已被 .gitignore 忽略，不会进 git。

# ===== 飞书应用密钥（从飞书开放平台获取）=====
FEISHU_XIAONAO_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_XIAONAO_SECRET=你的小闹app_secret
FEISHU_XIAOZHI_APP_ID=cli_yyyyyyyyyyyyyyyy
FEISHU_XIAOZHI_SECRET=你的小知app_secret

# 飞书群 chat_id
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== AI 模型（OpenAI 兼容接口）=====
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
AI_API_BASE=https://apihub.agnes-ai.com/v1
AI_MODEL=agnes-2.0-flash

# ===== 多维表格同步应用（史官，纯后端，不需要机器人身份，不拉群）=====
BITABLE_APP_ID=cli_xxxxxxxxxxxxxxxx
BITABLE_APP_SECRET=你的史官app_secret
BITABLE_APP_TOKEN=从多维表格URL获取_base_或_wiki_后面那串
BITABLE_TABLE_IDS={"log":"tblXXX","observation":"tblXXX","task":"tblXXX","goal":"tblXXX"}
